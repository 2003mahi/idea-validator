# ─────────────────────────────────────────────────────────────────────────────
# CrazeCheck – required environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in the values from your
# Supabase project dashboard: https://supabase.com/dashboard/project/<id>/settings/api
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of your Supabase project (e.g. https://<ref>.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public API key  (also accepted as VITE_SUPABASE_PUBLISHABLE_KEY)
VITE_SUPABASE_ANON_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Kept for backwards-compatibility; either name is accepted by the client.
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project reference ID (only needed if you use Supabase CLI locally)
# VITE_SUPABASE_PROJECT_ID=
